{
  // ESLint 8 pinned: v9 flat-config breaks @typescript-eslint v7 plugin compat.
  "root": true,
  // @typescript-eslint parser enables type-aware linting via tsconfig.json.
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.eslint.json"
  },
  "plugins": ["@typescript-eslint", "jest"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:jest/recommended"
  ],
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "rules": {
    // Underscore-prefixed vars/args are intentional (e.g., unused callback params).
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    // Encourages `import type` for type-only imports (tree-shaking clarity).
    "@typescript-eslint/consistent-type-imports": "warn",
    "no-console": "warn"
  },
  "ignorePatterns": ["dist/", "node_modules/", "coverage/", "*.js"]
}
